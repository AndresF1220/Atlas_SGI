rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isAuthOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin() || isAuthOwner(userId);
      allow list: if request.query.keys().hasOnly(['cedula', 'status']);
    }

    match /settings/app {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /settings/company {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /areas/{areaId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /areas/{areaId}/{allChildren=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /caracterizaciones/{caracterizacionId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /folders/{folderId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /documents/{documentId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /indicadores/{indicadorId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /mediciones/{medicionId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /categorias/{categoriaId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
  }
}